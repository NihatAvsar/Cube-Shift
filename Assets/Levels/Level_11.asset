    h0; (5,6) h0; (5,5) h0; (5,4) h0; (5,3) h0; (6,3) h0; (8,3) h0; (9,3) h0; (9,4)
    h0; (9,5) h0; (9,6) h0; (12,6) h0; (13,6) h0; (13,7) h0; (13,8) h0; (13,9) h0;
